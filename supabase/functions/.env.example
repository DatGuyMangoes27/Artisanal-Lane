SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
TRADESAFE_CLIENT_ID=your-tradesafe-client-id
TRADESAFE_CLIENT_SECRET=your-tradesafe-client-secret
TRADESAFE_CALLBACK_SECRET=choose-a-random-callback-secret
TRADESAFE_AUTH_URL=https://auth.tradesafe.co.za/oauth/token
TRADESAFE_GRAPHQL_URL=https://api.tradesafe.co.za/graphql
PAYFAST_MERCHANT_ID=your-payfast-merchant-id
PAYFAST_MERCHANT_KEY=your-payfast-merchant-key
