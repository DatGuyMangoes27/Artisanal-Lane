# PAYFAST_PASSPHRASE=your-payfast-passphrase
PAYFAST_SANDBOX=true
COURIER_GUY_API_KEY=your-tcg-locker-api-key
# Defaults to the TCG Locker sandbox docs host; override with the live base URL when ready.
COURIER_GUY_API_BASE_URL=https://sandbox.api-pudo.co.za
